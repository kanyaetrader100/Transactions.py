import pandas as pd
import os
from datetime import datetime

accounts_path = r"C:\Users\Sibongile\Main.py\accounts.csv"
df = pd.read_csv(accounts_path, skipinitialspace=True)

def process_payment():
    name = input("\nEnter customer name: \n")
    
    customer = df[df["Name"].str.lower() == name.lower()]
    
    if customer.empty:
        print("Account not found ❌")
        return
    
    print(f"\nAccount found ✅")
    print(customer.to_string(index=False))
    
    # Then ask for amount
    amount = float(input("\nEnter transaction amount: R"))
    
    # Print receipt
    print(f"\n--- RECEIPT ---")
    print(f"Customer: {name}")
    print(f"Amount: R{amount}")
    print(f"Date: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"Status: Approved ✅")

process_payment()
